---
import 'xp.css';
import '../styles/desktop.css';
import MarkdownIt from 'markdown-it';
import { db } from '../lib/db';
import { SITE_TITLE } from '../lib/site';

// html stays off (default): raw HTML in the bio markdown is escaped
const md = new MarkdownIt({ linkify: true });

interface Props {
  title?: string;
  description?: string;
  windowLabel?: string;
}
const { title = SITE_TITLE, description, windowLabel = 'Posts' } = Astro.props;

type Link = { id: number; label: string; icon_filename: string | null; kind: string; url: string };
const links = db
  .prepare('SELECT id, label, icon_filename, kind, url FROM links WHERE visible = 1 ORDER BY sort_order, id')
  .all() as Link[];
const iconSrc = (l: Link) =>
  l.icon_filename
    ? `/uploads/${l.icon_filename}`
    : l.kind === 'window'
      ? '/icons/generic-text-document.png' // uploaded documents
      : '/favicon.svg';

// start-menu bio; personal text/photo live in the settings table, never in code
const settings = Object.fromEntries(
  (
    db.prepare("SELECT key, value FROM settings WHERE key IN ('about', 'bio_name', 'bio_photo')").all() as {
      key: string;
      value: string;
    }[]
  ).map((r) => [r.key, r.value])
);
const bioName = settings.bio_name || SITE_TITLE;
const bioPhoto = settings.bio_photo ? `/uploads/${settings.bio_photo}` : '/favicon.svg';
const bioHtml = md.render(settings.about ?? '');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <slot name="head" />
  </head>
  <body data-site-title={SITE_TITLE}>
    <main class="desktop">
      <div class="icons">
        <a class="icon" href="/posts">
          <span class="icon-img"><img src="/icons/generic-text-document.png" alt="" width="48" height="48" /></span>
          <span>Posts</span>
        </a>
        {links.map((l) =>
          l.kind === 'external' ? (
            <a class="icon external" href={l.url} target="_blank" rel="noopener">
              <span class="icon-img"><img src={iconSrc(l)} alt="" width="48" height="48" /></span>
              <span>{l.label}</span>
            </a>
          ) : (
            <button class="icon" data-open={`window-${l.id}`}>
              <span class="icon-img"><img src={iconSrc(l)} alt="" width="48" height="48" /></span>
              <span>{l.label}</span>
            </button>
          )
        )}
        {/* shown to everyone: the desktop page is edge-cached, so its HTML must
            not vary by session. Clicking it just lands on the /admin login. */}
        <a class="icon control-panel" href="/admin">
          <span class="icon-img"><img src="/icons/control-panel.png" alt="" width="48" height="48" /></span>
          <span>Control Panel</span>
        </a>
      </div>

      {links
        .filter((l) => l.kind === 'window')
        .map((l) => (
          <div class="window pdf-window" id={`window-${l.id}`} role="dialog" aria-label={l.label} data-taskbar-icon={iconSrc(l)} hidden>
            <div class="title-bar">
              <div class="title-bar-text">{l.label}</div>
              <div class="title-bar-controls">
                <button aria-label="Close" data-close />
              </div>
            </div>
            <iframe data-src={l.url} title={l.label}></iframe>
          </div>
        ))}

      {/* posts window: SSR-filled via the named slot on /posts URLs, filled by
          the swap script when opened from the desktop — no page reload, so
          other open windows survive */}
      <div
        class="window content-window"
        role="dialog"
        aria-label={windowLabel}
        hidden={!Astro.slots.has('posts-window')}
      >
        <slot name="posts-window" />
      </div>

      <slot />
    </main>
    <footer class="taskbar">
      <button class="start-button" popovertarget="start-menu">Start</button>
      <div class="task-buttons"></div>
      <time class="tray-clock"></time>
    </footer>

    {/* popover: top layer + click-outside/Esc dismissal, no JS needed */}
    <div id="start-menu" class="start-menu" popover>
      <header>
        <img src={bioPhoto} alt="" width="56" height="56" />
        <span>{bioName}</span>
      </header>
      <div class="start-menu-body" set:html={bioHtml} />
      <footer>
        <button popovertarget="start-menu" popovertargetaction="hide">
          <img src="/icons/power.png" alt="" width="24" height="24" /> Turn Off Computer
        </button>
      </footer>
    </div>

    <script>
      // tray clock: the client's local time, so it's rendered here, not SSR'd
      const clock = document.querySelector<HTMLElement>('.tray-clock')!;
      const tick = () => {
        clock.textContent = new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
      };
      tick();
      setInterval(tick, 1000);

      // --- taskbar window buttons, XP semantics: every open window gets a
      // button; click focuses, clicking the focused one minimizes, close
      // removes it. "Minimized" is hidden + data-minimized (button stays).
      const strip = document.querySelector<HTMLElement>('.task-buttons')!;
      const wins = [...document.querySelectorAll<HTMLElement>('.desktop .window:not(dialog)')];
      const taskButtons = new Map<HTMLElement, HTMLButtonElement>();
      let z = 10;
      let active: HTMLElement | null = null;

      const sync = () => {
        for (const [win, btn] of taskButtons) {
          const closed = win.hidden && win.dataset.minimized === undefined;
          // fresh open (not a minimize-restore, which never hides the button):
          // XP appends newly opened windows to the right end of the strip
          if (btn.hidden && !closed) strip.append(btn);
          btn.hidden = closed;
          btn.querySelector('span')!.textContent = win.querySelector('.title-bar-text')?.textContent ?? '';
          btn.classList.toggle('active', active === win && !win.hidden);
        }
      };

      const raise = (win: HTMLElement) => {
        win.style.zIndex = String(++z);
        active = win;
        sync();
      };

      for (const win of wins) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'task-button';
        const img = document.createElement('img');
        img.alt = '';
        img.src =
          win.dataset.taskbarIcon ??
          (win.classList.contains('admin-window') ? '/icons/control-panel.png' : '/icons/generic-text-document.png');
        btn.append(img, document.createElement('span'));
        btn.addEventListener('click', () => {
          if (win.hidden) {
            delete win.dataset.minimized;
            win.hidden = false;
            raise(win);
          } else if (active === win) {
            win.dataset.minimized = '';
            win.hidden = true;
          } else {
            raise(win);
          }
        });
        taskButtons.set(win, btn);
        strip.append(btn);
      }

      // closes from any code path (X buttons, popstate, swaps) stay in sync
      const winObserver = new MutationObserver(() => {
        if (active?.hidden) active = null;
        sync();
      });
      wins.forEach((w) => winObserver.observe(w, { attributeFilter: ['hidden'] }));
      active = wins.filter((w) => !w.hidden).pop() ?? null;
      sync();

      document.querySelectorAll<HTMLElement>('[data-open]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const win = document.getElementById(btn.dataset.open!)!;
          const frame = win.querySelector('iframe')!;
          if (!frame.src) frame.src = frame.dataset.src!; // load the PDF on first open only
          delete win.dataset.minimized;
          win.hidden = false;
          raise(win);
        });
      });
      document.querySelectorAll<HTMLElement>('[data-close]').forEach((btn) => {
        btn.addEventListener('click', () => {
          btn.closest<HTMLElement>('.window')!.hidden = true;
        });
      });

      // drag (title bar, delegated from the window so content swaps survive)
      // + click-to-front; resize is native CSS `resize: both`
      // dialogs live in the top layer and center via margins; leave them alone
      document.querySelectorAll<HTMLElement>('.desktop .window:not(dialog)').forEach((win) => {
        win.addEventListener('pointerdown', (e) => {
          raise(win);
          const target = e.target as HTMLElement;
          if (!target.closest('.title-bar') || target.closest('button, a')) return;
          const rect = win.getBoundingClientRect();
          // switch from centered transform to px coordinates so deltas apply cleanly
          win.style.transform = 'none';
          win.style.left = `${rect.left}px`;
          win.style.top = `${rect.top}px`;
          const offsetX = e.clientX - rect.left;
          const offsetY = e.clientY - rect.top;
          // pointer capture keeps the drag alive even over the PDF iframe
          win.setPointerCapture(e.pointerId);
          const move = (ev: PointerEvent) => {
            const left = Math.max(48 - rect.width, Math.min(ev.clientX - offsetX, innerWidth - 48));
            const top = Math.max(0, Math.min(ev.clientY - offsetY, innerHeight - 40));
            win.style.left = `${left}px`;
            win.style.top = `${top}px`;
          };
          const up = (ev: PointerEvent) => {
            win.releasePointerCapture(ev.pointerId);
            win.removeEventListener('pointermove', move);
            win.removeEventListener('pointerup', up);
          };
          win.addEventListener('pointermove', move);
          win.addEventListener('pointerup', up);
        });
      });

      // in-window navigation: swap only the open window's contents and
      // pushState the URL — no page re-render, window keeps its position.
      // Direct loads and crawlers still get full SSR pages.
      const cw = document.querySelector<HTMLElement>('.content-window');
      if (cw) {
        const swap = async (href: string, push: boolean) => {
          try {
            const res = await fetch(href);
            if (!res.ok) throw new Error();
            const doc = new DOMParser().parseFromString(await res.text(), 'text/html');
            const next = doc.querySelector('.content-window');
            if (!next) throw new Error();
            cw.innerHTML = next.innerHTML;
            cw.setAttribute('aria-label', next.getAttribute('aria-label') ?? '');
            cw.hidden = false;
            document.title = doc.title;
            raise(cw); // focus it and refresh the taskbar (raise calls sync)
            if (push) history.pushState({}, '', href);
          } catch {
            location.href = href; // fall back to a real navigation
          }
        };
        // any same-origin /posts link — the desktop icon, links inside the
        // window, the start-menu bio — opens in the window instead of navigating
        document.addEventListener('click', (e) => {
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return; // keep open-in-new-tab
          const a = (e.target as HTMLElement).closest('a');
          if (!a || a.target || a.origin !== location.origin || !a.pathname.startsWith('/posts')) return;
          e.preventDefault();
          swap(a.href, true);
        });
        // closing hides the window and lands on the live desktop — no reload
        const siteTitle = document.body.dataset.siteTitle ?? '';
        cw.addEventListener('submit', (e) => {
          e.preventDefault();
          cw.hidden = true;
          history.pushState({}, '', '/');
          document.title = siteTitle;
        });
        addEventListener('popstate', () => {
          if (location.pathname.startsWith('/posts')) swap(location.pathname, false);
          else if (location.pathname === '/') {
            cw.hidden = true;
            document.title = siteTitle;
          } else location.reload();
        });
      }
    </script>
  </body>
</html>
