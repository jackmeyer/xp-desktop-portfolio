---
import Desktop from '../../layouts/Desktop.astro';
import { createSession, rateLimited, recordFailedLogin, sessionCookieOptions, verifyLogin } from '../../lib/auth';
import { SITE_TITLE } from '../../lib/site';

if (Astro.locals.user) return Astro.redirect('/admin');

let error = '';
if (Astro.request.method === 'POST') {
  if (rateLimited(Astro.clientAddress)) {
    error = 'Too many attempts. Try again later.';
  } else {
    const form = await Astro.request.formData();
    const user = await verifyLogin(
      String(form.get('email') ?? ''),
      String(form.get('password') ?? '')
    );
    if (user) {
      Astro.cookies.set('session', createSession(user.id), sessionCookieOptions);
      return Astro.redirect('/admin');
    }
    recordFailedLogin(Astro.clientAddress);
    error = 'Invalid email or password.';
  }
}
---

<Desktop title="Log On">
  <div class="window admin-window" role="dialog" aria-label="Log On" style="width: min(320px, 90vw)">
    <div class="title-bar">
      <div class="title-bar-text">Log On to {SITE_TITLE}</div>
      <div class="title-bar-controls">
        <form method="get" action="/"><button aria-label="Close"></button></form>
      </div>
    </div>
    <div class="window-body">
      <form method="post">
        <div class="field-row-stacked">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="username" />
        </div>
        <div class="field-row-stacked">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" required autocomplete="current-password" />
        </div>
        {error && <p role="alert">{error}</p>}
        <section class="field-row" style="justify-content: flex-end">
          <button type="submit">OK</button>
        </section>
      </form>
    </div>
  </div>
</Desktop>
