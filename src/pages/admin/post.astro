---
import MarkdownIt from 'markdown-it';
import Desktop from '../../layouts/Desktop.astro';
import { db } from '../../lib/db';

// html stays off (default): raw HTML in markdown is escaped, so the rendered
// output is safe without a separate sanitizer
const md = new MarkdownIt({ linkify: true });

type Post = {
  id: number;
  slug: string;
  title: string;
  summary: string;
  body_md: string;
  body_html: string;
  status: string;
  published_at: string | null;
  updated_at: string;
};

let error = '';
let id = Number(Astro.url.searchParams.get('id')) || null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  id = Number(form.get('id')) || null;
  const title = String(form.get('title') ?? '').trim();
  const summary = String(form.get('summary') ?? '').trim();
  const bodyMd = String(form.get('body_md') ?? '');
  const slug = (String(form.get('slug') ?? '').trim() || title)
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');

  if (!title) error = 'Title is required.';
  else if (!slug) error = 'Slug is required.';

  if (!error) {
    const bodyHtml = md.render(bodyMd);
    try {
      if (id) {
        db.prepare(
          "UPDATE posts SET slug = ?, title = ?, summary = ?, body_md = ?, body_html = ?, updated_at = datetime('now') WHERE id = ?"
        ).run(slug, title, summary, bodyMd, bodyHtml, id);
      } else {
        id = Number(
          db
            .prepare('INSERT INTO posts (slug, title, summary, body_md, body_html) VALUES (?, ?, ?, ?, ?)')
            .run(slug, title, summary, bodyMd, bodyHtml).lastInsertRowid
        );
      }
      return Astro.redirect(`/admin/post?id=${id}&saved=1`);
    } catch (e) {
      error =
        e instanceof Error && e.message.includes('UNIQUE')
          ? 'That slug is already used by another post.'
          : 'Save failed.';
    }
  }
}

const post = id ? (db.prepare('SELECT * FROM posts WHERE id = ?').get(id) as Post | undefined) : undefined;
const saved = Astro.url.searchParams.get('saved') === '1';
---

<Desktop title={post ? `Edit: ${post.title}` : 'New post'}>
  <div class="window admin-window" role="dialog" aria-label="Post editor" style="width: min(900px, 95vw)">
    <div class="title-bar">
      <div class="title-bar-text">{post?.title || 'Untitled'}.md — Notepad</div>
      <div class="title-bar-controls">
        <form method="get" action="/admin">
          <input type="hidden" name="tab" value="posts" />
          <button aria-label="Close"></button>
        </form>
      </div>
    </div>
    <div class="window-body" style="overflow: auto">
        <p><a href="/admin?tab=posts">← Back to posts</a></p>
        {saved && <p role="status">Saved.</p>}
        <form method="post">
          {id && <input type="hidden" name="id" value={id} />}
          <div class="field-row-stacked">
            <label for="title">Title</label>
            <input id="title" name="title" required value={post?.title ?? ''} />
          </div>
          <div class="field-row-stacked">
            <label for="slug">Slug (leave empty to derive from title)</label>
            <input id="slug" name="slug" value={post?.slug ?? ''} />
          </div>
          <div class="field-row-stacked">
            <label for="summary">Summary</label>
            <input id="summary" name="summary" value={post?.summary ?? ''} />
          </div>
          <div class="field-row-stacked">
            <label for="body_md">Body (Markdown, rendered on save)</label>
            <textarea id="body_md" name="body_md" rows="20" style="font-family: monospace">{post?.body_md ?? ''}</textarea>
          </div>
          {error && <p role="alert">{error}</p>}
          <div class="field-row" style="justify-content: space-between">
            <span>{post ? `Status: ${post.status}` : 'New draft'}</span>
            <button type="submit">Save</button>
          </div>
        </form>

        {post?.body_html && (
          <fieldset style="margin-top: 12px">
            <legend>Preview (as of last save)</legend>
            <div style="background: #fff; padding: 12px" set:html={post.body_html} />
          </fieldset>
        )}
    </div>
  </div>
</Desktop>
