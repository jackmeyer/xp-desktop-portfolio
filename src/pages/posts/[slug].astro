---
import Desktop from '../../layouts/Desktop.astro';
import { db } from '../../lib/db';
import { SITE_TITLE } from '../../lib/site';

type Post = { title: string; summary: string; body_html: string; published_at: string };
const post = db
  .prepare(
    "SELECT title, summary, body_html, published_at FROM posts WHERE slug = ? AND status = 'published'"
  )
  .get(Astro.params.slug) as Post | undefined;

if (!post) return new Response('Not found', { status: 404 });
---

<Desktop title={`${post.title} — ${SITE_TITLE}`} description={post.summary} windowLabel={post.title}>
  <Fragment slot="head">
    <meta property="og:title" content={post.title} />
    {post.summary && <meta property="og:description" content={post.summary} />}
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={post.published_at} />
  </Fragment>

  <Fragment slot="posts-window">
    <div class="title-bar">
      <div class="title-bar-text">{post.title} — Posts</div>
      <div class="title-bar-controls">
        <form method="get" action="/"><button aria-label="Close"></button></form>
      </div>
    </div>
    <div class="window-body content-body">
      <p><a href="/posts">← All notes</a></p>
      <article>
        <h1>{post.title}</h1>
        <time datetime={post.published_at}>{post.published_at.slice(0, 10)}</time>
        <div set:html={post.body_html} />
      </article>
    </div>
  </Fragment>
</Desktop>
